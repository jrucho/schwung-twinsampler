{
  "title": "TwinSampler",
  "children": [
    {
      "title": "Core Layout",
      "lines": [
        "Two independent 4x4",
        "sections (Left/Right).",
        "Each section has",
        "8 banks x 16 slots.",
        "",
        "Default: Left=Source",
        "Right=Per-Pad"
      ]
    },
    {
      "title": "Pad + Bank",
      "lines": [
        "Pads are side-by-side",
        "4x4 Left + 4x4 Right",
        "on the 4x8 matrix.",
        "Cols 1-4 = Left",
        "Cols 5-8 = Right",
        "",
        "Tap pad to focus slot",
        "and section.",
        "",
        "Overtake bank select:",
        "Step 1-8 = Left B1-8",
        "Step 9-16 = Right B1-8",
        "",
        "Shift+Step: copy bank",
        "source -> destination",
        "while Shift is held",
        "",
        "Shift+Vol+Step:",
        "clear that bank",
        "",
        "Delete:",
        "clear focused pad",
        "Shift+Delete:",
        "clear focused bank",
        "Undo / Shift+Undo:",
        "undo / redo",
        "Master knob:",
        "no gain mapping",
        "inside TwinSampler",
        "",
        "Back=background",
        "Shift+Vol+Back",
        "exit module"
      ]
    },
    {
      "title": "Copy Pads",
      "lines": [
        "Hold Shift + tap pad",
        "to set copy source.",
        "",
        "Keep Shift held and",
        "tap another pad to",
        "paste/copy there.",
        "",
        "Release Shift to",
        "clear copy source."
      ]
    },
    {
      "title": "Pad Colors",
      "lines": [
        "Hold Shift +",
        "Volume touch, then:",
        "",
        "K1: Color mode",
        "K2: EMU bit depth",
        "K3: EMU sample rate",
        "K4: EMU drv+comp",
        "Touch K1-4 shows",
        "current values",
        "",
        "K5 turn: edit scope",
        "Pad / Bank",
        "",
        "K6 turn: copy SRC",
        "bank to all banks",
        "",
        "K7 turn: bank color",
        "K8 turn: pad color",
        "(or BANK inherit)",
        "",
        "Color edit is gated",
        "to avoid interfering",
        "with normal controls."
      ]
    },
    {
      "title": "Mode + Browser",
      "lines": [
        "Shift + jog turn:",
        "section mode",
        "(Source / Per-Pad)",
        "",
        "Source mode uses",
        "fixed 16 chops",
        "with long tails",
        "and bank choke.",
        "",
        "Shift + K1-K5:",
        "bank edit Atk/Dec",
        "Start/End/Mode",
        "",
        "Shift + K6 turn:",
        "source bank pitch",
        "Shift + K7 turn:",
        "bank gain",
        "Shift + K8 turn:",
        "bank loop",
        "",
        "Jog click:",
        "open samples browser",
        "Shift+Menu:",
        "session load menu",
        "Shift+Copy:",
        "session save menu",
        "Shift+Vol+Jog:",
        "session load menu",
        "",
        "Jog turn in browser:",
        "scroll files",
        "WAV highlight:",
        "auto-preview",
        "Jog click in browser:",
        "enter/load selected"
      ]
    },
    {
      "title": "Sessions",
      "lines": [
        "Autosave runs when",
        "you change state and",
        "also on module exit.",
        "",
        "Shift + Copy:",
        "open save menu",
        "",
        "Shift + Menu:",
        "open load menu",
        "",
        "Session browser:",
        "K1=char index",
        "K2=char value",
        "Copy=save or name",
        "Menu=load selected",
        "",
        "Shift+Menu:",
        "rename selected",
        "Shift+Copy:",
        "save current name",
        "Shift+Vol+Copy:",
        "duplicate selected",
        "Delete:",
        "delete selected",
        "INIT session is",
        "always available",
        "and is locked"
      ]
    },
    {
      "title": "Record",
      "lines": [
        "Rec button",
        "(main view):",
        "1x arm monitor",
        "(LED blinks)",
        "2x start record",
        "(monitor on)",
        "3x stop record",
        "+monitor off",
        "",
        "Shift+Rec while",
        "recording: stop",
        "and load file to",
        "focused source/pad",
        "",
        "Shift + jog click",
        "(browser): close",
        "browser",
        "",
        "LoopPad mode:",
        "Shift+pad=copy",
        "Del+pad erase",
        "playing loop MIDI",
        "",
        "Capture button:",
        "randomize focused",
        "source bank chops"
      ]
    }
  ]
}
